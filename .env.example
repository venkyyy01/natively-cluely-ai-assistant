# ── Cloud AI Providers (at least one required) ──
# Get keys from: https://aistudio.google.com, https://console.groq.com, https://platform.openai.com, https://console.anthropic.com
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=

# ── Speech Provider (for transcription) ──
# Get key from: https://console.deepgram.com
DEEPGRAM_API_KEY=

# ── Local AI via Ollama (free alternative) ──
USE_OLLAMA=true
OLLAMA_MODEL=llama3.2
OLLAMA_URL=http://localhost:11434

# ── Default Model ──
DEFAULT_MODEL=gemini-3.1-flash-lite-preview
